{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git rm *)",
      "Bash(uv run *)",
      "Bash(git check-ignore *)",
      "Bash(grep -E \"^\\(plan|spec|build|test|ship|review|code-simplify|docs-manager\\)$\")",
      "Bash(git mv *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/claude-stop-checks.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/graphify-pretool.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pretool-block-destructive.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/pretool-warn-package-remove.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pretool-block-graphify-out.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/pretool-warn-secret-file.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pretool-block-graphify-out.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/pretool-warn-secret-file.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/graphify-auto-refresh.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/posttool-check-secrets-on-git.sh"
          }
        ]
      }
    ]
  }
}
